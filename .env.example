# LLM Configuration
OPENAI_API_KEY=your_openai_api_key_here
TOGETHER_API_KEY=your_together_api_key_here
LLM_BACKEND=openai  # Options: openai, ollama, together
LLM_MODEL=gpt-4o-mini  # For together: meta-llama/Llama-4-Maverick-17B-128E-Instruct-FP8

# GROBID Configuration
GROBID_URL=http://localhost:8070

# Pipeline Configuration
MAX_CONCURRENCY=10
